# =============================================================================
# Panshulo Homelab — Environment Variables (ejemplo)
# =============================================================================
# Copia este archivo a .env y completa tus valores.
# NUNCA subas .env con valores reales a GitHub.
# =============================================================================

# ── Usuario ────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=America/Santiago
HOSTNAME=panshulo

# ── Directorios ────────────────────────────────────────────────────────────
CONFIG_DIR=/path/to/docker/configs
MEDIA_DIR=/path/to/media
DOWNLOADS_DIR=/path/to/downloads

# ── Gitea ──────────────────────────────────────────────────────────────────
GITEA_DOMAIN=git.yourdomain.com
GITEA_URL=https://git.yourdomain.com

# ── Plex ───────────────────────────────────────────────────────────────────
# Obtén tu token en: https://www.plex.tv/claim
PLEX_CLAIM=claim-xxxxxxxxxx
